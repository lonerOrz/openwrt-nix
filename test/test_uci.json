{
  "settings": {
    "system": {
      "system": {
        "_type": "system",
        "hostname": "test-router"
      }
    },
    "network": {
      "lan": {
        "_type": "interface",
        "ifname": "eth0",
        "proto": "static"
      }
    },
    "dropbear": {
      "dropbear": [
        {
          "_type": "dropbear",
          "PasswordAuth": "off",
          "Port": "2222"
        },
        {
          "_type": "dropbear",
          "PasswordAuth": "on",
          "Port": "22"
        }
      ]
    },
    "wireless": {
      "default_radio0": {
        "_type": "wifi-iface",
        "device": "radio0",
        "network": "lan",
        "mode": "ap",
        "ssid": "test-ssid",
        "encryption": "none"
      }
    }
  }
}
