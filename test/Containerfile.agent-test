# Containerfile for ssh-agent lockout prevention testing
# Has password auth enabled and NO pre-configured SSH keys
# Used to verify that nuci deploy correctly deploys ssh-agent keys

ARG OPENWRT_VERSION=latest
FROM docker.io/openwrt/rootfs:${OPENWRT_VERSION}

RUN mkdir -p /var/lock /var/run /etc/dropbear /etc/opkg /etc/apk/repositories.d
RUN touch /etc/config/system /etc/config/wireless /etc/config/network

# Mock opkg/apk if not present
RUN if ! command -v opkg >/dev/null 2>&1; then \
      printf '#!/bin/sh\necho "opkg $*" >> /tmp/opkg.log\nif [ "$1" = "list-installed" ]; then exit 1; fi\nexit 0\n' \
        > /usr/bin/opkg && chmod +x /usr/bin/opkg; \
    fi
RUN if ! command -v apk >/dev/null 2>&1; then \
      printf '#!/bin/sh\necho "apk $*" >> /tmp/apk.log\nif [ "$1" = "info" ] && [ "$2" = "-e" ]; then exit 1; fi\nexit 0\n' \
        > /usr/bin/apk && chmod +x /usr/bin/apk; \
    fi

# Set root password
RUN printf 'root\nroot\n' | passwd root

# Password auth ENABLED, no SSH keys pre-installed
# This simulates a fresh device that needs SSH key deployment

EXPOSE 22

RUN printf '#!/bin/sh\n/etc/init.d/dropbear start\nexec sleep infinity\n' \
    > /start.sh && chmod +x /start.sh
CMD ["/start.sh"]
